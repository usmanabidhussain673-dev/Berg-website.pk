<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Berg Shampoo Store</title>

<style>
body {
  font-family: Arial;
  background: #f5f5f5;
  text-align: center;
}

header {
  padding: 20px;
  background: #2e7d32;
  color: white;
}

.logo {
  width: 200px;
}

.products {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.card {
  background: white;
  width: 260px;
  margin: 10px;
  padding: 10px;
  border-radius: 10px;
}

.card img, video {
  width: 100%;
  border-radius: 10px;
}

.btn {
  display: block;
  background: #25D366;
  color: white;
  padding: 10px;
  margin-top: 10px;
  text-decoration: none;
}

.cod {
  background: orange;
  border: none;
  padding: 10px;
  width: 100%;
  margin-top: 5px;
}
</style>

</head>

<body>

<!-- 🔷 Logo -->
<header>
  <img src="images/logo.png" class="logo">
  <h2>Berg Shampoo Store</h2>
</header>

<div class="products">

  <!-- 100ml -->
  <div class="card">
    <img src="images/100ml.jpg">
    <video controls src="videos/100ml.mp4"></video>
    <h3>Shampoo 100ml</h3>
    <p><del>Rs. 175</del> <strong>Rs. 150</strong></p>
    <a href="https://wa.me/923368783688" class="btn">Order on WhatsApp</a>
    <button class="cod">Cash on Delivery</button>
  </div>

  <!-- 200ml -->
  <div class="card">
    <img src="images/200ml.jpg">
    <video controls src="videos/200ml.mp4"></video>
    <h3>Shampoo 200ml</h3>
    <p><del>Rs. 300</del> <strong>Rs. 280</strong></p>
    <a href="https://wa.me/923368783688" class="btn">Order on WhatsApp</a>
    <button class="cod">Cash on Delivery</button>
  </div>

  <!-- 400ml -->
  <div class="card">
    <img src="images/400ml.jpg">
    <video controls src="videos/400ml.mp4"></video>
    <h3>Shampoo 400ml</h3>
    <p><del>Rs. 600</del> <strong>Rs. 520</strong></p>
    <a href="https://wa.me/923368783688" class="btn">Order on WhatsApp</a>
    <button class="cod">Cash on Delivery</button>
  </div>

  <!-- 500ml -->
  <div class="card">
    <img src="images/500ml.jpg">
    <video controls src="videos/500ml.mp4"></video>
    <h3>Shampoo 500ml</h3>
    <p><del>Rs. 320</del> <strong>Rs. 300</strong></p>
    <a href="https://wa.me/923368783688" class="btn">Order on WhatsApp</a>
    <button class="cod">Cash on Delivery</button>
  </div>

  <!-- 750ml -->
  <div class="card">
    <img src="images/750ml.jpg">
    <video controls src="videos/750ml.mp4"></video>
    <h3>Shampoo 750ml</h3>
    <p><del>Rs. 1050</del> <strong>Rs. 890</strong></p>
    <a href="https://wa.me/923368783688" class="btn">Order on WhatsApp</a>
    <button class="cod">Cash on Delivery</button>
  </div>

  <!-- 1000ml -->
  <div class="card">
    <img src="images/1000ml.jpg">
    <video controls src="videos/1000ml.mp4"></video>
    <h3>Shampoo 1000ml</h3>
    <p><del>Rs. 800</del> <strong>Rs. 700</strong></p>
    <a href="https://wa.me/923368783688" class="btn">Order on WhatsApp</a>
    <button class="cod">Cash on Delivery</button>
  </div>

</div>

</body>
</html>
